# =============================================================================
# .gitignore — Painel SISPAGAER (monorepo)
# Cobre raiz, frontend/ e backend/ em arquivo único.
# =============================================================================

# =============================================================================
# SEGURANÇA — nunca versionar
# =============================================================================
.env
.env.*
*.env
!.env.example
!frontend/.env.example
secrets/
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-production.properties

# =============================================================================
# JAVA — compilação
# =============================================================================
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# =============================================================================
# MAVEN
# =============================================================================
backend/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
backend/.mvn/timing.properties
backend/.mvn/wrapper/maven-wrapper.jar

# =============================================================================
# QUARKUS
# =============================================================================
*-runner
*-runner.jar
backend/.quarkus/
backend/src/main/resources/META-INF/openapi.yaml
backend/src/generated/
backend/target/kubernetes/
backend/jacoco.exec
backend/.jacoco/

# =============================================================================
# NODE / FRONTEND
# =============================================================================
frontend/node_modules/
frontend/dist/

# =============================================================================
# DOCKER — overrides e dados locais
# =============================================================================
docker-compose.override.yml
docker-compose.local.yml
db/data/

# =============================================================================
# INTELLIJ IDEA
# =============================================================================
.idea/
*.iws
*.iml
*.ipr
out/

# =============================================================================
# SISTEMA OPERACIONAL — Windows
# =============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# SISTEMA OPERACIONAL — macOS / Linux
# =============================================================================
.DS_Store
.Spotlight-V100
.Trashes
*~
.fuse_hidden*
.nfs*

# =============================================================================
# EDITORES DIVERSOS
# =============================================================================
.vscode/
*.suo
*.sw?

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# CI / CD
# =============================================================================
.cache/
