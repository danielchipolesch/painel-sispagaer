# =============================================================================
# PAINEL SISPAGAER — Variáveis de ambiente
#
# PRODUÇÃO: copie este arquivo para .env (nunca commitar o .env real)
#           $ cp .env.example .env
#           Preencha os valores reais e execute:
#           $ docker compose --profile production up -d --build
#
# DESENVOLVIMENTO: não precisa criar .env — os valores padrão já funcionam.
#                  $ docker compose up
# =============================================================================

# ---------------------------------------------------------------------------
# API Key — autenticação entre frontend e backend
# OBRIGATÓRIO: use o mesmo valor nos dois campos abaixo.
# Gere uma chave forte com: openssl rand -hex 32
# ---------------------------------------------------------------------------
API_KEY=troque-por-uma-chave-forte-de-64-caracteres
VITE_API_KEY=troque-por-uma-chave-forte-de-64-caracteres

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
DB_USERNAME=sispagaer
DB_PASSWORD=troque-por-senha-forte

# ---------------------------------------------------------------------------
# CORS — origens permitidas para acessar o backend
# Use a URL real do frontend em produção (sem barra no final).
# Múltiplas origens separadas por vírgula.
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://seu-dominio.fab.mil.br
